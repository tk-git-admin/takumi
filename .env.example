# Server-only Basic Auth configuration for Cloudflare Workers.
NUXT_BASIC_AUTH_USERNAME=
NUXT_BASIC_AUTH_PASSWORD=
NUXT_BASIC_AUTH_ENABLED=false

# Optional comma-separated hostnames that should require Basic Auth even when globally disabled.
NUXT_BASIC_AUTH_PREVIEW_HOSTNAMES=

# Google Tag Manager + Consent Mode v2.
# Public build-time container ID; safe to expose in browser HTML.
NUXT_PUBLIC_GTM_ID=GTM-NJP9WCVD

# Kuroco read-only static API tokens. Server-only; do not prefix with NUXT_PUBLIC_.
KUROCO_HOMEPAGE_TOKEN=
KUROCO_NEWS_TOKEN=
KUROCO_PRODUCTS_TOKEN=
KUROCO_KNIVES_TOKEN=
