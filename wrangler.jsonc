{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "takumi",
	"main": "./.output/server/index.mjs",
	"compatibility_date": "2026-06-08",
	"compatibility_flags": ["nodejs_compat", "no_nodejs_compat_v2"],
	"preview_urls": true,
	"assets": {
		"binding": "ASSETS",
		"directory": "./.output/public"
	}
}
