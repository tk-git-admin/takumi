{
	"name": "nuxt-app",
	"private": true,
	"scripts": {
		"build": "nuxt build",
		"dev": "volta run --node 18.19.0 nuxt dev",
		"preview": "nuxt preview",
		"start": "node .output/server/index.mjs",
		"test": "node --test tests/*.test.mjs",
		"postinstall": "nuxt prepare",
		"prettier-check": "prettier . --check",
		"prettier-write": "prettier . --write",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@nuxt/devtools": "1.0.8",
		"@nuxtjs/i18n": "8.1.1",
		"@nuxtjs/tailwindcss": "6.11.4",
		"@types/node": "18.19.20",
		"daisyui": "4.7.2",
		"husky": "^8.0.3",
		"lint-staged": "^15.2.0",
		"nuxt": "3.10.3",
		"nuxt-icon": "0.6.8",
		"prettier": "3.1.1",
		"sass": "1.71.1"
	},
	"dependencies": {
		"@fancyapps/ui": "^5.0.24",
		"@fortawesome/fontawesome-free": "^6.4.0",
		"@pinia/nuxt": "^0.5.1",
		"aos": "^2.3.4",
		"pinia": "^2.1.7",
		"vue-scrollto": "^2.20.0",
		"vue-toastification": "^2.0.0-rc.5",
		"vue3-carousel": "^0.3.1"
	},
	"type": "module",
	"overrides": {
		"vue": "3.4.21"
	},
	"volta": {
		"node": "18.19.0"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,md,html,css,vue}": "npm run prettier-write"
	}
}
