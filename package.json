{
	"name": "nuxt-app",
	"private": true,
	"scripts": {
		"build": "nuxt build",
		"deploy": "npx wrangler --cwd .output deploy",
		"dev": "volta run --node 20.19.0 nuxt dev",
		"preview": "nuxt preview",
		"start": "node .output/server/index.mjs",
		"test": "node --test tests/*.test.mjs",
		"postinstall": "nuxt prepare",
		"prettier-check": "prettier . --check",
		"prettier-write": "prettier . --write",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@nuxt/devtools": "2.3.2",
		"@nuxt/schema": "3.16.2",
		"@nuxtjs/i18n": "8.1.1",
		"@nuxtjs/tailwindcss": "6.11.4",
		"@types/node": "18.19.20",
		"daisyui": "4.7.2",
		"husky": "^8.0.3",
		"lint-staged": "^15.2.0",
		"nuxt": "3.16.2",
		"nuxt-icon": "0.6.8",
		"prettier": "3.1.1",
		"sass": "1.71.1",
		"wrangler": "4.24.0"
	},
	"dependencies": {
		"@fancyapps/ui": "^5.0.24",
		"@fortawesome/fontawesome-free": "^6.4.0",
		"@pinia/nuxt": "^0.5.1",
		"aos": "^2.3.4",
		"pinia": "^2.1.7",
		"vue-scrollto": "^2.20.0",
		"vue-toastification": "^2.0.0-rc.5",
		"vue3-carousel": "^0.3.1"
	},
	"type": "module",
	"overrides": {
		"@nuxt/cli": "3.24.0",
		"@nuxt/devtools": "2.3.2",
		"c12": "3.0.4",
		"impound": "0.2.2",
		"nitropack": {
			".": "2.11.13",
			"unimport": "5.2.0",
			"unplugin-utils": "0.2.4"
		},
		"unstorage": "1.17.3",
		"unimport": {
			".": "5.2.0",
			"unplugin-utils": "0.2.4"
		},
		"unplugin-utils": "0.2.4",
		"vite": "6.3.5",
		"vue": "3.5.13"
	},
	"volta": {
		"node": "20.19.0"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,md,html,css,vue}": "npm run prettier-write"
	}
}
